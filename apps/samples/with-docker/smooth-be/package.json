{
  "name": "SMOOTH-BALLOT-BE",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start:vps": "npx pm2 start npm -- start:prod",
    "start:docker": "npm run migrate && node dist/main",
    "start": "npm run migrate && nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "migrate": "npm run build && npx sequelize-cli db:migrate",
    "migrate:prod": "npx sequelize-cli db:migrate",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "docker:local": "docker-compose down && docker-compose up -d",
    "test:e2e:local": "npm run docker && cross-env NODE_ENV=test npm run migrate && jest --config ./test/jest-e2e.json",
    "test:e2e": "npx jest --testPathPattern=_tests_/e2e"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.591.0",
    "@aws-sdk/s3-request-presigner": "^3.591.0",
    "@grpc/grpc-js": "^1.11.1",
    "@grpc/proto-loader": "^0.7.13",
    "@nestjs/bull": "^10.1.1",
    "@nestjs/bullmq": "^10.1.1",
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/microservices": "^10.3.10",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/schedule": "^4.0.2",
    "@plunk/node": "^3.0.0",
    "@types/pdfkit": "^0.13.4",
    "axios": "^1.7.9",
    "bcryptjs": "^2.4.3",
    "bull": "^4.12.9",
    "cookie-parser": "^1.4.6",
    "cross-env": "^7.0.3",
    "csvtojson": "^2.0.10",
    "dotenv": "^16.4.5",
    "ioredis": "^5.4.1",
    "joi": "^17.13.1",
    "jsonwebtoken": "^9.0.2",
    "moment": "^2.30.1",
    "mongoose": "^8.7.2",
    "morgan": "^1.10.0",
    "mysql2": "^3.9.7",
    "nodemailer": "^6.9.14",
    "otp-generator": "^4.0.1",
    "papaparse": "^5.4.1",
    "paseto": "^3.1.4",
    "paystack-sdk": "^2.5.13",
    "pdfkit": "^0.15.0",
    "pg": "^8.11.5",
    "pg-hstore": "^2.3.4",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.0",
    "request": "^2.88.2",
    "resend": "^4.1.2",
    "rxjs": "^7.8.1",
    "sequelize": "^6.37.3",
    "slugify": "^1.6.6"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.2",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/moment": "^2.13.0",
    "@types/node": "^20.3.1",
    "@types/nodemailer": "^6.4.15",
    "@types/otp-generator": "^4.0.2",
    "@types/papaparse": "^5.3.14",
    "@types/request": "^2.48.12",
    "@types/supertest": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.42.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "sequelize-cli": "^6.6.2",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsc-alias": "^1.8.8",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "@modules/(.*)$": "<rootDir>/src/modules/$1",
      "@db/(.*)$": "<rootDir>/src/db/$1",
      "@utils/(.*)$": "<rootDir>/src/utils/$1",
      "@env/(.*)$": "<rootDir>/src/environment/$1",
      "@cache/(.*)$": "<rootDir>/src/cache/$1",
      "@validators/(.*)$": "<rootDir>/src/validators/$1",
      "@decorators/(.*)$": "<rootDir>/src/decorators/$1",
      "src/(.*)$": "<rootDir>/src/$1",
      "src/super-admin/protos/(.*)": "<rootDir>/src/super-admin/protos/$1"
    }
  }
}
